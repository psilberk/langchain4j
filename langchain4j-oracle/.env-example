ORACLE_CONNECT_STRING=jdbc:oracle:thin:@<host>:1521:<service>
ORACLE_USER=<user>
ORACLE_PASSWORD=<password>

# data source settings

DEMO_DS_PDF_FILE=</path/to/file.pdf>
DEMO_DS_TEXT_FILE=</path/to/file.txt>

DEMO_DS_DIR=<dir>

DEMO_DS_OWNER=<user>
DEMO_DS_TABLE=<table>
DEMO_DS_COLUMN=<column>

# proxy for REST calls
DEMO_PROXY=<host>:<port>

# ONNX model
DEMO_ONNX_DIR=<dir>
DEMO_ONNX_FILE=<file>
DEMO_ONNX_MODEL=<name>
